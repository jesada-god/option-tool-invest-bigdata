# Optional. Leave blank unless you use the legacy LINE notification function.
LINE_ACCESS_TOKEN=

# Render supplies PORT automatically. This value is only for local runs.
PORT=8000

# Optional PostgreSQL cloud-sync foundation. Leave blank to keep the legacy
# in-memory demo mode; the app does not connect to a database until new
# authenticated routes explicitly use this configuration.
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=
# Optional direct connection only for `alembic upgrade head` (recommended
# when DATABASE_URL points at a transaction pooler such as Supabase).
DATABASE_URL_DIRECT=
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800

# Supabase Auth uses only the public anon key here. Keep service-role keys out
# of this app and out of the browser. PUBLIC_APP_URL must be your exact Render
# URL (or custom HTTPS domain) before enabling Google OAuth in production.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Set true only after Google is enabled in the Supabase Auth dashboard and its
# callback URL is registered in Google Cloud Console.
SUPABASE_GOOGLE_ENABLED=false
# Required (32+ random characters) before the Google button is enabled. Used
# only to sign an HttpOnly, short-lived PKCE transaction cookie.
AUTH_STATE_SECRET=
AUTH_OAUTH_TRANSACTION_TTL_SECONDS=600
PUBLIC_APP_URL=
AUTH_COOKIE_SECURE=true
SUPABASE_REQUEST_TIMEOUT_SECONDS=10
# The in-process auth limiter protects the single-worker service. Set proxy
# headers true only behind Render/another trusted reverse proxy.
AUTH_RATE_LIMIT_PER_MINUTE=12
# Bounds unauthenticated CPU-heavy What-if/Monte Carlo requests per client.
COMPUTE_RATE_LIMIT_PER_MINUTE=6
# Bounds browser resume/snapshot quote calls per client; WebSocket fan-out is
# bounded separately below.
QUOTE_RATE_LIMIT_PER_MINUTE=120
TRUST_PROXY_HEADERS=false

# Optional incident-only diagnostics. When blank, /api/debug/yfinance and the
# process-wide cache endpoints are disabled. Never expose this value to a
# browser or commit it to Git.
OPERATIONS_TOKEN=

# Market data. yfinance is a best-effort polling fallback, not a licensed
# exchange stream. Set MARKET_DATA_PROVIDER=polygon and add a Polygon key for
# a licensed last-trade source permitted by your Polygon subscription.
MARKET_DATA_PROVIDER=yfinance
POLYGON_API_KEY=
QUOTE_REGULAR_POLL_SECONDS=3
QUOTE_OFF_HOURS_POLL_SECONDS=15
MARKET_DATA_TIMEOUT_SECONDS=12
MARKET_DATA_MAX_CONCURRENCY=8
LIVE_PRICE_STALE_SECONDS=120
# Bounds process-local quote state against arbitrary public ticker/connection
# sprays. Keep the defaults unless the host has enough upstream data capacity.
LIVE_PRICE_CACHE_TTL_SECONDS=900
LIVE_PRICE_CACHE_MAX_TICKERS=1000
LIVE_QUOTE_MAX_ACTIVE_TICKERS=200
LIVE_QUOTE_MAX_CONNECTIONS=2000

# Durable in-app price/S&R alerts are evaluated only from verified fresh
# quotes. They run detached from quote delivery and stay bounded so a slow
# database never freezes live prices. A dedicated worker is still required
# for closed-tab, push, email, news, IV, and earnings delivery at scale.
ALERT_PRICE_EVALUATION_MIN_INTERVAL_SECONDS=5
ALERT_PREVIOUS_QUOTE_MAX_AGE_SECONDS=30
ALERT_EVALUATION_MAX_CONCURRENCY=2

